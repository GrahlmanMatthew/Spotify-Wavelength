# Your Spotify app's Client ID.
# Get it from: https://developer.spotify.com/dashboard → your app → Settings
# This is NOT a secret — it is embedded in the built JS bundle by design (PKCE flow).
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# The redirect URI Spotify sends the auth code back to.
# Must exactly match one of the URIs registered in your Spotify Developer app settings.
# Local dev:    http://127.0.0.1:5173/
# GitHub Pages: https://GrahlmanMatthew.github.io/Spotify-Wavelength/
VITE_REDIRECT_URI=http://127.0.0.1:5173/
